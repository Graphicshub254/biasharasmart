# =============================================================================
# BiasharaSmart Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to git
# =============================================================================

# =============================================================================
# DATABASE (T0.4)
# =============================================================================
DATABASE_URL=postgresql://biasharasmart:devpass@localhost:5432/biasharasmart_dev
REDIS_URL=redis://localhost:6379

# =============================================================================
# AUTH (T1.1)
# =============================================================================
JWT_SECRET=your_jwt_secret_min_32_chars_here
JWT_EXPIRES_IN=7d
BIOMETRIC_SALT=your_biometric_salt_here

# =============================================================================
# KRA GAVACONNECT — eTIMS + TCC (T1.3, T1.5, T2.1)
# Sandbox: https://sandbox.gavaconnect.co.ke
# Production: https://api.gavaconnect.co.ke
# =============================================================================
GAVACONNECT_BASE_URL=https://sandbox.gavaconnect.co.ke
GAVACONNECT_API_KEY=your_gavaconnect_api_key_here
GAVACONNECT_VENDOR_ID=your_vendor_id_here

# =============================================================================
# SAFARICOM DARAJA — STK Push + B2C (T1.4, T3.1)
# Sandbox credentials from developer.safaricom.co.ke
# =============================================================================
DARAJA_ENV=sandbox
DARAJA_CONSUMER_KEY=your_consumer_key_here
DARAJA_CONSUMER_SECRET=your_consumer_secret_here
DARAJA_PAYBILL=174379
DARAJA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
DARAJA_CALLBACK_URL=http://localhost:3000/api/payments/mpesa/callback
DARAJA_TIMEOUT_URL=http://localhost:3000/api/payments/mpesa/timeout
DARAJA_RESULT_URL=http://localhost:3000/api/payments/mpesa/result

# B2C (Payroll - T3.1)
DARAJA_B2C_INITIATOR_NAME=your_initiator_name_here
DARAJA_B2C_SECURITY_CREDENTIAL=your_security_credential_here
DARAJA_B2C_QUEUE_TIMEOUT_URL=http://localhost:3000/api/payroll/mpesa/timeout
DARAJA_B2C_RESULT_URL=http://localhost:3000/api/payroll/mpesa/result

# =============================================================================
# AWS S3 — KYC document storage (T1.1)
# =============================================================================
AWS_REGION=af-south-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_S3_BUCKET=biasharasmart-kyc-sandbox

# =============================================================================
# FIREBASE — Push notifications (T1.4, T2.3)
# =============================================================================
FCM_PROJECT_ID=your_firebase_project_id
FCM_PRIVATE_KEY=your_firebase_private_key_here
FCM_CLIENT_EMAIL=your_firebase_client_email_here

# =============================================================================
# AFRICA'S TALKING — SMS fallback (T2.3)
# =============================================================================
AT_API_KEY=your_africastalking_api_key_here
AT_USERNAME=sandbox
AT_SENDER_ID=BiasharaSmart

# =============================================================================
# WHATSAPP BUSINESS API — Receipts + TCC alerts (T2.3, T3.4)
# =============================================================================
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_ACCESS_TOKEN=your_whatsapp_token_here
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token_here

# =============================================================================
# CLAUDE API — AI Business Advisor (T2.2)
# =============================================================================
CLAUDE_API_KEY=your_anthropic_api_key_here
CLAUDE_HAIKU_MODEL=claude-haiku-4-5-20251001
CLAUDE_SONNET_MODEL=claude-sonnet-4-6

# =============================================================================
# CO-OP BANK — Loan referral (T3.3)
# =============================================================================
COOP_API_URL=https://sandbox.co-opbank.co.ke
COOP_API_KEY=your_coop_api_key_here
COOP_PARTNER_ID=your_partner_id_here

# =============================================================================
# APP CONFIG
# =============================================================================
NODE_ENV=development
PORT=3000
APP_NAME=BiasharaSmart
APP_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:8081

# =============================================================================
# NGROK — Local webhook testing (dev only)
# Run: ngrok http 3000
# Paste the https URL here for Daraja callbacks
# =============================================================================
NGROK_URL=https://your-ngrok-url.ngrok-free.app